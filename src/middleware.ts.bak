import { NextResponse, type NextRequest } from 'next/server'
import { updateSession } from '@/lib/supabase/middleware'

export async function middleware(request: NextRequest) {
    // Skip all API routes to avoid interference with NextAuth, webhooks, etc.
    if (request.nextUrl.pathname.startsWith('/api/')) {
        return NextResponse.next()
    }

    try {
        const response = await updateSession(request)
        // Add CSP for development if needed
        if (process.env.NODE_ENV === 'development') {
            response.headers.set('Content-Security-Policy', "script-src 'self' 'unsafe-eval' 'unsafe-inline' https:; object-src 'none';")
        }
        return response
    } catch (e) {
        console.error("Middleware error:", e)
        return NextResponse.next()
    }
}

export const config = {
    matcher: [
        /*
         * Match all request paths except for the ones starting with:
         * - api (API routes)
         * - _next/static (static files)
         * - _next/image (image optimization files)
         * - favicon.ico (favicon file)
         */
        '/((?!api|_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',
    ],
}
